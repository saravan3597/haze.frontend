<?xml version="1.0" encoding="utf-8"?>
<!-- Capacitor SplashScreen drawable.
     The splash.png generated by scripts/generate-icons.cjs already contains
     the black background + haze mark, so we just centre it on a black field. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <color android:color="#000000" />
    </item>
    <item>
        <bitmap
            android:src="@drawable/splash_img"
            android:gravity="center"
            android:tileMode="disabled" />
    </item>
</layer-list>
